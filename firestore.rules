rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          request.auth.token.admin == true
          // 초기 개발용 임시 관리자 이메일. 배포 전 실제 이메일로 바꾸거나 custom claim을 사용하세요.
          || request.auth.token.email in ['djmonnar4@gmail.com']
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function signedInUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedResident() {
      return isSignedIn()
        && signedInUserProfile().apartmentId == 'pradium'
        && signedInUserProfile().approvalStatus == 'approved';
    }

    function validUserCreate(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'phone',
          'building',
          'unit',
          'nickname',
          'apartmentId',
          'role',
          'approvalStatus',
          'createdAt',
          'approvedAt',
          'approvedBy'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.nickname is string
        && request.resource.data.apartmentId == 'pradium'
        && request.resource.data.role == 'resident'
        && request.resource.data.approvalStatus == 'pending'
        && request.resource.data.approvedAt == null
        && request.resource.data.approvedBy == null;
    }

    function userSelfUpdateKeepsProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'uid',
          'email',
          'apartmentId',
          'role',
          'approvalStatus',
          'approvedAt',
          'approvedBy'
        ]);
    }

    // 입주민/관리자/파트너 프로필
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && validUserCreate(uid);
      allow update: if isAdmin()
                    || (isOwner(uid) && userSelfUpdateKeepsProtectedFields());
      allow delete: if isAdmin();
    }

    function validGroupBuyApplicationCreate(appId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'groupBuyId',
          'groupBuyTitle',
          'apartmentId',
          'userId',
          'userName',
          'phone',
          'building',
          'unit',
          'memo',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && appId == request.resource.data.groupBuyId + '_' + request.auth.uid
        && request.resource.data.id == appId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.apartmentId == 'pradium'
        && request.resource.data.status == 'applied'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function userCancelsOwnApplication() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status in ['applied', 'checking']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ])
        && request.resource.data.status == 'cancelled'
        && request.resource.data.updatedAt == request.time;
    }

    // 공동구매 신청
    match /groupBuyApplications/{appId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isAdmin() || isApprovedResident())
                    && validGroupBuyApplicationCreate(appId);
      allow update: if isAdmin() || userCancelsOwnApplication();
      allow delete: if isAdmin();
    }

    function validApartmentInquiryCreate() {
      return request.resource.data.keys().hasOnly([
          'apartmentName',
          'region',
          'householdCount',
          'contactName',
          'role',
          'phone',
          'message',
          'internalMemo',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.apartmentName is string
        && request.resource.data.region is string
        && request.resource.data.householdCount is string
        && request.resource.data.contactName is string
        && request.resource.data.role in [
          'residentRepresentative',
          'managementOffice',
          'resident',
          'etc'
        ]
        && request.resource.data.phone is string
        && request.resource.data.message is string
        && request.resource.data.internalMemo == ''
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /apartmentInquiries/{inquiryId} {
      allow create: if validApartmentInquiryCreate();
      allow read, update, delete: if isAdmin();
    }

    function validPartnerInquiryCreate() {
      return request.resource.data.keys().hasOnly([
          'businessName',
          'category',
          'contactName',
          'phone',
          'region',
          'message',
          'internalMemo',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.businessName is string
        && request.resource.data.category is string
        && request.resource.data.contactName is string
        && request.resource.data.phone is string
        && request.resource.data.region is string
        && request.resource.data.message is string
        && request.resource.data.internalMemo == ''
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /partnerInquiries/{inquiryId} {
      allow create: if validPartnerInquiryCreate();
      allow read, update, delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if isAdmin() || resource.data.status == 'active';
      allow create, update, delete: if isAdmin();
    }

    match /benefits/{benefitId} {
      allow read: if isAdmin() || resource.data.status == 'active';
      allow create, update, delete: if isAdmin();
    }

    function validCouponCreate(couponId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'code',
          'apartmentId',
          'userId',
          'benefitId',
          'benefitTitle',
          'partnerId',
          'partnerName',
          'status',
          'issuedAt',
          'expiresAt',
          'usedAt',
          'usedByPartnerId',
          'usedByPartnerName'
        ])
        && request.resource.data.id == couponId
        && request.resource.data.code is string
        && request.resource.data.apartmentId == 'pradium'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.benefitId is string
        && request.resource.data.benefitTitle is string
        && request.resource.data.partnerId is string
        && request.resource.data.partnerName is string
        && request.resource.data.status == 'issued'
        && request.resource.data.issuedAt == request.time
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.usedAt == null
        && request.resource.data.usedByPartnerId == null
        && request.resource.data.usedByPartnerName == null;
    }

    match /coupons/{couponId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isAdmin() || isApprovedResident())
                    && validCouponCreate(couponId);
      allow update, delete: if isAdmin();
    }

    function validBenefitRedemptionCreate(redemptionId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'apartmentId',
          'userId',
          'benefitId',
          'benefitTitle',
          'partnerId',
          'partnerName',
          'periodKey',
          'status',
          'createdAt',
          'usedAt',
          'usedBy',
          'monthlyLimit'
        ])
        && request.resource.data.id == redemptionId
        && request.resource.data.apartmentId == 'pradium'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.benefitId is string
        && request.resource.data.benefitTitle is string
        && request.resource.data.partnerId is string
        && request.resource.data.partnerName is string
        && request.resource.data.periodKey is string
        && request.resource.data.status == 'ready'
        && request.resource.data.createdAt == request.time
        && request.resource.data.usedAt == null
        && request.resource.data.usedBy == null
        && request.resource.data.monthlyLimit is number
        && request.resource.data.monthlyLimit >= 1;
    }

    match /benefitRedemptions/{redemptionId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isAdmin() || isApprovedResident())
                    && validBenefitRedemptionCreate(redemptionId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /benefitUsagePeriods/{usageId} {
      allow get: if isAdmin()
                 || (
                   isSignedIn()
                   && (
                     (
                       exists(/databases/$(database)/documents/benefitUsagePeriods/$(usageId))
                       && resource.data.userId == request.auth.uid
                     )
                     || (
                       !exists(/databases/$(database)/documents/benefitUsagePeriods/$(usageId))
                       && usageId.matches('^' + request.auth.uid + '_.*')
                     )
                   )
                 );
      allow list: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    function validCommunityCategory(value) {
      return value in ['free', 'group_request', 'market', 'local_info'];
    }

    function validCommunityReportReason(value) {
      return value in ['spam', 'abuse', 'privacy', 'commercial', 'etc'];
    }

    function validCommunityPostCreate(postId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'apartmentId',
          'category',
          'tags',
          'title',
          'content',
          'authorId',
          'authorNickname',
          'status',
          'isNotice',
          'isPinned',
          'commentCount',
          'likeCount',
          'reportCount',
          'viewCount',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == postId
        && request.resource.data.apartmentId == 'pradium'
        && validCommunityCategory(request.resource.data.category)
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 3
        && request.resource.data.title is string
        && request.resource.data.content is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorNickname is string
        && request.resource.data.status == 'published'
        && request.resource.data.isNotice == false
        && request.resource.data.isPinned == false
        && request.resource.data.commentCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.reportCount == 0
        && request.resource.data.viewCount == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function communityPostOwnerEdits() {
      return isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'category',
          'tags',
          'title',
          'content',
          'updatedAt'
        ])
        && validCommunityCategory(request.resource.data.category)
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 3
        && request.resource.data.title is string
        && request.resource.data.content is string
        && request.resource.data.updatedAt == request.time;
    }

    function communityPostOwnerDeletes() {
      return isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ])
        && request.resource.data.status == 'deleted'
        && request.resource.data.updatedAt == request.time;
    }

    function communityPostCommentCountIncrements() {
      return (isApprovedResident() || isAdmin())
        && resource.data.status == 'published'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'commentCount',
          'updatedAt'
        ])
        && request.resource.data.commentCount == resource.data.commentCount + 1
        && request.resource.data.updatedAt == request.time;
    }

    function communityPostReportCountIncrements(postId) {
      let reportId = 'post_' + postId + '_' + request.auth.uid;
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'reportCount',
          'updatedAt'
        ])
        && request.resource.data.reportCount == resource.data.reportCount + 1
        && request.resource.data.updatedAt == request.time
        && !exists(/databases/$(database)/documents/communityReports/$(reportId))
        && existsAfter(/databases/$(database)/documents/communityReports/$(reportId));
    }

    match /communityPosts/{postId} {
      allow read: if isAdmin()
                  || resource.data.status == 'published'
                  || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow create: if (isApprovedResident() || isAdmin())
                    && validCommunityPostCreate(postId);
      allow update: if isAdmin()
                    || communityPostOwnerEdits()
                    || communityPostOwnerDeletes()
                    || communityPostCommentCountIncrements()
                    || communityPostReportCountIncrements(postId);
      allow delete: if isAdmin();
    }

    function validCommunityCommentCreate(commentId) {
      let postId = request.resource.data.postId;
      return request.resource.data.keys().hasOnly([
          'id',
          'postId',
          'apartmentId',
          'content',
          'authorId',
          'authorNickname',
          'status',
          'reportCount',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == commentId
        && postId is string
        && exists(/databases/$(database)/documents/communityPosts/$(postId))
        && get(/databases/$(database)/documents/communityPosts/$(postId)).data.status == 'published'
        && request.resource.data.apartmentId == 'pradium'
        && request.resource.data.content is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorNickname is string
        && request.resource.data.status == 'published'
        && request.resource.data.reportCount == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function communityCommentOwnerDeletes() {
      return isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ])
        && request.resource.data.status == 'deleted'
        && request.resource.data.updatedAt == request.time;
    }

    function communityCommentReportCountIncrements(commentId) {
      let reportId = 'comment_' + commentId + '_' + request.auth.uid;
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'reportCount',
          'updatedAt'
        ])
        && request.resource.data.reportCount == resource.data.reportCount + 1
        && request.resource.data.updatedAt == request.time
        && !exists(/databases/$(database)/documents/communityReports/$(reportId))
        && existsAfter(/databases/$(database)/documents/communityReports/$(reportId));
    }

    match /communityComments/{commentId} {
      allow read: if isAdmin()
                  || resource.data.status == 'published'
                  || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow create: if (isApprovedResident() || isAdmin())
                    && validCommunityCommentCreate(commentId);
      allow update: if isAdmin()
                    || communityCommentOwnerDeletes()
                    || communityCommentReportCountIncrements(commentId);
      allow delete: if isAdmin();
    }

    function validCommunityReportCreate(reportId) {
      let targetType = request.resource.data.targetType;
      let targetId = request.resource.data.targetId;
      return request.resource.data.keys().hasOnly([
          'id',
          'targetType',
          'targetId',
          'postId',
          'reporterId',
          'reason',
          'message',
          'createdAt'
        ])
        && request.resource.data.id == reportId
        && targetType in ['post', 'comment']
        && targetId is string
        && reportId == targetType + '_' + targetId + '_' + request.auth.uid
        && request.resource.data.postId is string
        && (
          (
            targetType == 'post'
            && request.resource.data.postId == targetId
            && exists(/databases/$(database)/documents/communityPosts/$(targetId))
          )
          || (
            targetType == 'comment'
            && exists(/databases/$(database)/documents/communityComments/$(targetId))
          )
        )
        && request.resource.data.reporterId == request.auth.uid
        && validCommunityReportReason(request.resource.data.reason)
        && request.resource.data.message is string
        && request.resource.data.createdAt == request.time;
    }

    match /communityReports/{reportId} {
      allow create: if isSignedIn() && validCommunityReportCreate(reportId);
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
